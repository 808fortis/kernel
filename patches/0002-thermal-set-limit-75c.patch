From: Custom <custom@kernel>
Date: Thu, 21 May 2026 21:42:00 +0000
Subject: thermal: set temperature limit to 75C

---
 arch/arm64/boot/dts/sprd/ums312-mach.dtsi | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(-)

diff --git a/arch/arm64/boot/dts/sprd/ums312-mach.dtsi b/arch/arm64/boot/dts/sprd/ums312-mach.dtsi
index 0000000..0000000
--- a/arch/arm64/boot/dts/sprd/ums312-mach.dtsi
+++ b/arch/arm64/boot/dts/sprd/ums312-mach.dtsi
@@ -1,15 +1,15 @@
 soc_threshold: trip-point@0 {
-	temperature = <70000>;
+	temperature = <65000>;
 	hysteresis = <1000>;
 	type = "passive";
 };
 soc_target: trip-point@1 {
-	temperature = <85000>;
+	temperature = <75000>;
 	hysteresis = <1000>;
 	type = "passive";
 };
 soc_crit: soc_crit {
-	temperature = <110000>;
+	temperature = <80000>;
 	hysteresis = <2000>;
 	type = "critical";
 };
